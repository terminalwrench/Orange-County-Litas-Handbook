# Frontend Supabase access. Use the anon public key only.
# Founder/admin users are created manually in Supabase Auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override for the read-only Events calendar import.
# Defaults to the public Orange County Litas Google Calendar ICS feed when blank.
VITE_EVENTS_ICS_URL=

# Optional Supabase Edge Function name for server-side ICS fetching.
# Defaults to import-events-ics.
VITE_EVENTS_ICS_FUNCTION_NAME=
